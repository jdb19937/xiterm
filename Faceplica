# Faceplica — aedificatio xiterm
#
# Usus:
#   face            — aedifica xiterm
#   face purga      — dele omnia aedificata
#
# Requirit: phantasma installata in /opt/apotheca

PREFIX      = /opt/apotheca
PHANTASMA   = $(PREFIX)/lib/libphantasma.a
OBJECTA     = xiterm.o pty.o
CAPITA      = pty.h
LITTERAE    = mork_16.gif titulus_16.gif they_16.gif ahoy_16.gif

omnia: xiterm titulus_genera mork_genera they_genera $(LITTERAE)

xiterm.o: xiterm.c $(CAPITA)
	ccc -I/opt/apotheca/include $<

pty.o: pty.c $(CAPITA)
	ccc $<

xiterm: xiterm.o pty.o $(PHANTASMA)
	ldi `cat $(PREFIX)/lib/nexus_phantasma` $^

titulus_genera.o: titulus_genera.c
	ccc -I/opt/apotheca/include $<

titulus_genera: titulus_genera.o $(PHANTASMA)
	ldi `cat $(PREFIX)/lib/nexus_phantasma` $^

mork_genera.o: mork_genera.c
	ccc -I/opt/apotheca/include $<

mork_genera: mork_genera.o $(PHANTASMA)
	ldi `cat $(PREFIX)/lib/nexus_phantasma` $^

they_genera.o: they_genera.c
	ccc -I/opt/apotheca/include $<

they_genera: they_genera.o $(PHANTASMA)
	ldi `cat $(PREFIX)/lib/nexus_phantasma` $^

titulus_16.gif: titulus_genera
	./titulus_genera

mork_16.gif: mork_genera
	./mork_genera

they_16.gif: they_genera
	./they_genera

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 xiterm $(PREFIX)/bin/
	install -d $(PREFIX)/var/xiterm
	install -m 644 $(LITTERAE) $(PREFIX)/var/xiterm/

purga:
	rm -f $(OBJECTA) xiterm titulus_genera.o titulus_genera \
		mork_16.gif they_16.gif titulus_16.gif \
		mork_genera.o mork_genera they_genera.o they_genera

.PHONY: omnia colloca purga
